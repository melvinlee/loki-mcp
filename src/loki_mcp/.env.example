# Loki server URL (default: http://localhost:3100)
LOKI_URL=http://localhost:3100

# Basic auth credentials — leave blank if Loki is unauthenticated
# For Grafana Cloud, set LOKI_USERNAME to your numeric org ID
LOKI_USERNAME=
LOKI_PASSWORD=

# HTTP request timeout in seconds (default: 30)
LOKI_TIMEOUT=30
